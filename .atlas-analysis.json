  "keyFeatures": [
    "14 specialized AI agents running in parallel for comprehensive startup analysis",
    "Multi-provider AI support: Google Gemini 2.0 Flash and OpenRouter",
    "Asynchronous job processing with BullMQ + Redis for reliable queue management",
    "JWT + Google OAuth authentication with refresh token rotation",
    "Per-section report regeneration for targeted updates",
    "AI and rule-based grounding for final report quality assurance",
    "Usage-based plan limits (FREE: 3/month, PRO: 50/month, TEAM: unlimited)",
    "Monorepo with shared TypeScript types, validation, and normalization packages",
    "Docker Compose setup for local development and production deployment",
    "Redis-backed AI response caching (24-hour TTL)"
  ],
